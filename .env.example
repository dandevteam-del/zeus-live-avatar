# ═══════════════════════════════════════════════════════════════════════════════
# Zeus Live Avatar — Environment Configuration
# Opulent Bots LLC — All rights reserved
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Zeus Brain / MCP ─────────────────────────────────────────────────────────
ZEUS_BRAIN_URL=http://localhost:3000/message
ZEUS_BRAIN_WS_URL=ws://localhost:3000/ws
ZEUS_AUTH_TOKEN=changeme-generate-a-real-token

# ─── STT Service (faster-whisper) ─────────────────────────────────────────────
STT_MODEL_SIZE=base.en
# Options: tiny.en, base.en, small.en, medium.en, large-v3
STT_DEVICE=cuda
# Options: cuda, cpu
STT_COMPUTE_TYPE=float16
# Options: float16, int8, int8_float16
STT_VAD_THRESHOLD=0.5
STT_SILENCE_DURATION_MS=800
STT_HOST=0.0.0.0
STT_PORT=8001

# ─── TTS Service ─────────────────────────────────────────────────────────────
TTS_ENGINE=coqui
# Options: coqui, piper
TTS_HOST=0.0.0.0
TTS_PORT=8002

# Coqui TTS settings
COQUI_MODEL_NAME=tts_models/en/vctk/vits
# Good alternatives: tts_models/en/ljspeech/vits, tts_models/multilingual/multi-dataset/xtts_v2
COQUI_SPEAKER_ID=p225
COQUI_USE_CUDA=true

# Piper TTS settings (if TTS_ENGINE=piper)
PIPER_MODEL_PATH=/models/en_US-lessac-medium.onnx
PIPER_CONFIG_PATH=/models/en_US-lessac-medium.onnx.json
PIPER_SPEAKER_ID=0

# ─── Audio2Face Bridge ────────────────────────────────────────────────────────
A2F_BACKEND=sdk
# Options: sdk (open-source UE plugin), nim (NVIDIA NIM container)
A2F_HOST=0.0.0.0
A2F_PORT=8003
A2F_SAMPLE_RATE=16000
A2F_TARGET_FPS=60

# NVIDIA NIM settings (optional, requires NGC credentials)
# NGC_API_KEY=your-ngc-api-key
# A2F_NIM_IMAGE=nvcr.io/nvidia/ace/audio2face-3d:latest

# ─── Zeus Gateway ─────────────────────────────────────────────────────────────
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
GATEWAY_AUTH_TOKEN=changeme-operator-token

# Human timing engine (milliseconds)
TIMING_SIMPLE_MIN=200
TIMING_SIMPLE_MAX=600
TIMING_COMPLEX_MIN=700
TIMING_COMPLEX_MAX=1200
TIMING_PREFACE_RATE_LIMIT=3

# ─── Operator Console ────────────────────────────────────────────────────────
OPERATOR_PORT=8080
OPERATOR_AUTH_TOKEN=changeme-operator-token

# ─── Redis (Event Bus) ───────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── OBS ──────────────────────────────────────────────────────────────────────
OBS_WS_HOST=localhost
OBS_WS_PORT=4455
OBS_WS_PASSWORD=changeme-obs-password
OBS_SCENE_NAME=ZeusAvatar

# ─── Unreal Engine ────────────────────────────────────────────────────────────
UE_NDI_ENABLED=true
UE_RENDER_WIDTH=1920
UE_RENDER_HEIGHT=1080
UE_TARGET_FPS=30

# ─── General ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
# Options: debug, info, warning, error
